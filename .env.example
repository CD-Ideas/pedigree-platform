# Copy this to .env and fill in your values. Never commit .env to git.

# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/pedigree_platform?schema=public"

# Redis (for job queues)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="replace-with-256-bit-random-secret"
JWT_REFRESH_SECRET="replace-with-different-256-bit-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# AWS S3 (for image/document uploads)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_S3_BUCKET="pedigree-media-prod"
CLOUDFRONT_DOMAIN="cdn.yourpedigreesite.com"

# CORS — comma-separated allowed origins
"ALLOWED_ORIGINS=""http://localhost:3000,https://yourpedigreesite.com"""
